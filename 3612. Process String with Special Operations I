char* processStr(char* s) {
    int cap = 1 << 21;   // sufficient for constraints
    char *res = (char *)malloc(cap * sizeof(char));
    int len = 0;

    for (int i = 0; s[i]; i++) {
        if (s[i] >= 'a' && s[i] <= 'z') {
            res[len++] = s[i];
        }
        else if (s[i] == '*') {
            if (len > 0) len--;
        }
        else if (s[i] == '#') {
            memcpy(res + len, res, len);
            len *= 2;
        }
        else if (s[i] == '%') {
            int l = 0, r = len - 1;
            while (l < r) {
                char temp = res[l];
                res[l] = res[r];
                res[r] = temp;
                l++;
                r--;
            }
        }
    }

    res[len] = '\0';
    return res;
}

    
